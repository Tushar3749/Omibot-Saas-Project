# ─────────────────────────────────────────────
#  OmniBot SaaS — Backend Environment Variables
# ─────────────────────────────────────────────

# App
APP_NAME="OmniBot SaaS"
APP_VERSION="3.0.0"
DEBUG=false

# Supabase — go to supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google Gemini — console.cloud.google.com → AI Studio → API Keys
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Facebook / Meta — developers.facebook.com → Your App → Webhooks
FACEBOOK_APP_ID=123456789012345
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_VERIFY_TOKEN=your_custom_verify_token_string

# Sentry — sentry.io → New Project → Python → DSN
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Upstash Redis — upstash.com → Create Database → REST URL
REDIS_URL=redis://default:password@your-upstash-url:6379

# SSLCommerz — sslcommerz.com → Merchant Dashboard → Integration
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASS=your_store_password
SSLCOMMERZ_IS_SANDBOX=true

# AES Encryption — generate with: python -c "import secrets; print(secrets.token_hex(16))"
AES_SECRET_KEY=your_32_char_hex_aes_key_here____

# Cloudinary (product image hosting) — cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (password reset emails) — use Gmail App Password or any SMTP relay
# Gmail: enable 2FA → myaccount.google.com → App Passwords → generate 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=your_gmail@gmail.com

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
